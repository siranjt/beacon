# Beacon umbrella — environment variables
# Copy this file to .env.local for local dev, set actual values in Vercel for prod.

# NextAuth — required
NEXTAUTH_URL=https://beacon-v2.vercel.app
NEXTAUTH_SECRET=replace-with-random-32-byte-base64

# Google OAuth (single client across all agents)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email allowlist — only these domains can sign in
ALLOWED_EMAIL_DOMAINS=zoca.com,zoca.ai

# Customer Beacon — populated during Phase B migration
# DATABASE_URL=

# Performance Beacon — populated during Phase B migration
# METABASE_API_KEY=
# METABASE_BASE_URL=https://metabase.zoca.ai

# Escalation Beacon — populated during Phase C migration
# ANTHROPIC_API_KEY=
# CHARGEBEE_API_KEY=
# CHARGEBEE_SITE=zoca

# Post-Payment Beacon — populated during Phase D migration
# CHARGEBEE_WEBHOOK_USER=
# CHARGEBEE_WEBHOOK_PASS=
# CUSTOMER_FLOOR_DATE=2026-05-01
# VERCEL_BLOB_READ_WRITE_TOKEN=
# SLACK_WEBHOOK_URL=
