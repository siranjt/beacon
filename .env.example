# Beacon umbrella — environment variables
# Copy this file to .env.local for local dev, set actual values in Vercel for prod.

# NextAuth — required
NEXTAUTH_URL=https://beacon-v2.vercel.app
NEXTAUTH_SECRET=replace-with-random-32-byte-base64

# Google OAuth (single client across all agents)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email allowlist — only these domains can sign in
ALLOWED_EMAIL_DOMAINS=zoca.com,zoca.ai

# Customer Beacon — populated during Phase B migration
# DATABASE_URL=

# Performance Beacon — Metabase Dataset API (required for /performance)
# The API key inherits the permissions of the Metabase user/group it belongs to.
# Required permission: can_create_native_queries (verified Apr 2026).
METABASE_API_KEY=
METABASE_BASE_URL=https://metabase.zoca.ai

# Escalation Beacon — Anthropic + Chargebee + Metabase + optional webhook secret
# Anthropic: used by lib/escalation/agent.ts for triage / draft / summarize
ANTHROPIC_API_KEY=
# Chargebee (Zoca production site)
CHARGEBEE_SITE=zoca
CHARGEBEE_API_KEY=
# Metabase session token (BaseSheet card 1335; public CSVs work without it)
METABASE_SESSION_TOKEN=
# Optional: shared secret for incoming webhooks (POST /escalation/api/webhook)
# When set, the route requires `x-zoca-webhook-secret: <value>`
WEBHOOK_SHARED_SECRET=

# Post-Payment Beacon — Postgres + Blob + Stripe + Slack + ICP config
# Vercel Postgres connection strings (pull via: vercel env pull .env.development.local)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
# Vercel Blob — auto-injected on Vercel, set manually for local dev
BLOB_READ_WRITE_TOKEN=
# Stripe — used by lib/post-payment/validator/stripe.ts for dispute lookups
STRIPE_API_KEY=
# Anthropic model override (LLM evaluator)
ANTHROPIC_MODEL=claude-opus-4-6
# Slack — verdict notifications
SLACK_CHANNEL_ID=C0B2ECQMDR9
SLACK_BOT_TOKEN=
# App config
NEXT_PUBLIC_APP_URL=
CUSTOMER_FLOOR_DATE=2026-05-01
DISCOVERY_FILTER_PATTERN=discovery
COMMS_WINDOW_DAYS=90
TIMESTAMP_MISMATCH_HOURS=24
# Chargebee webhook secret — only required for the webhook receiver, which
# stays on the standalone deploy (zoca-payment-dashboard.vercel.app). Not
# needed in the umbrella unless you migrate the webhook later.
# CHARGEBEE_WEBHOOK_SECRET=
